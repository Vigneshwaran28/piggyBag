# Copy this file to local.properties (or a new secrets.properties and include it in build.gradle)
# Do NOT commit the actual values to version control.

# Google Web Client ID for Authentication
# Obtain from Google Cloud Console (APIs & Services > Credentials)
GOOGLE_WEB_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Base URL for the Cloud Sync API
CLOUD_BASE_URL=https://your-api-endpoint.com/
